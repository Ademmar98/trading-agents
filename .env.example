# Broker
BROKER_TYPE=paper
TRADING_CAPITAL=20000
TRADING_INTERVAL_MINUTES=60

# Markets: crypto (default), stocks, metals, or both (= all three)
# MARKET_TYPE=both

# Symbol universes per market (defaults shown); an explicit WATCHED_SYMBOLS
# overrides everything and is used exactly as given.
# CRYPTO_SYMBOLS=BTC/USD,ETH/USD,SOL/USD
# STOCK_SYMBOLS=AAPL,MSFT,NVDA,TSLA,AMZN,GOOGL,META,SPY
# METAL_SYMBOLS=XAUUSD,XAGUSD
# WATCHED_SYMBOLS=BTC/USD,ETH/USD,AAPL,XAUUSD

# Binance (testnet or live)
# BINANCE_API_KEY=
# BINANCE_API_SECRET=
# BINANCE_USE_TESTNET=true

# MetaQuotes 5 (Windows only)
# MT5_LOGIN=
# MT5_PASSWORD=
# MT5_SERVER=

# DXtrade (Velotrade funded accounts)
# DXTRADE_API_URL=
# DXTRADE_USERNAME=
# DXTRADE_PASSWORD=
# DXTRADE_DOMAIN=default

# Telegram notifications
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Web dashboard port
# PORT=8000

# Headless mode (no terminal dashboard, web still available)
# HEADLESS=true

# Wipe all data on next restart (⚠ removes trading history — use once then remove)
# RESET_ON_START=true

# Advanced
# TRAILING_STOP_PCT=3
# TRAILING_ACTIVATION_PCT=4
# STOP_LOSS_PCT=2.0
