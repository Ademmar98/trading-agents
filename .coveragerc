[run]
source = .
omit =
    tests/*
    data/*
    .venv/*
    venv/*
    __pycache__/*
    .git/*
    full_cycle_check.py
    prod_run.py

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    if __name__ == .__main__.:
    raise AssertionError
    raise NotImplementedError
    if 0:
    if False:
    if HEADLESS:
